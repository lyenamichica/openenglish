<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>なにかな？</title>
    <style>
        body {
            margin:0; height:100vh; 
            background:linear-gradient(#0a1f3d, #1e4d8c);
            overflow:hidden; 
            font-family:sans-serif; 
            color:white; 
            text-align:center;
            position:relative;
        }
        h1 {margin-top:20px; font-size:2.4em; text-shadow:0 0 15px #fff; z-index:10;}
        canvas {position:absolute; top:0; left:0; z-index:1;}
        #text-snow {position:absolute; top:0; left:0; width:100%; height:100%; z-index:2; display:none;}
        #final-scene {position:absolute; top:0; left:0; width:100%; height:100%; z-index:3; opacity:0; transition:opacity 4s;}
    </style>
</head>
<body>
    <h1>なにかな？</h1>
    <p style="margin:10px; font-size:1.3em; position:relative; z-index:10;">What is this?</p>
    <canvas id="canvas"></canvas>
    
    <!-- 文字の雪 -->
    <div id="text-snow"></div>
    
    <!-- 最後のsnowstopシーン -->
    <div id="final-scene">
        <div style="position:absolute; bottom:0; left:0; width:100%; height:45%; background:#f0f8ff; opacity:0.9;"></div>
        <!-- 白い雪だるま -->
        <div style="position:absolute; bottom:25%; left:50%; transform:translateX(-50%);">
            <div style="width:75px; height:75px; background:rgba(255,255,255,0.75); border-radius:50%; margin:0 auto;"></div>
            <div style="width:125px; height:125px; background:rgba(255,255,255,0.75); border-radius:50%; margin:-35px auto 0;"></div>
        </div>
    </div>

    <script>
        function startCycle() {
            // 白い雪
            const canvas = document.getElementById('canvas');
            const ctx = canvas.getContext('2d');
            let width, height;
            function resize() {
                width = canvas.width = window.innerWidth;
                height = canvas.height = window.innerHeight;
            }
            window.addEventListener('resize', resize);
            resize();

            class WhiteDot {
                constructor() { this.reset(); }
                reset() {
                    this.x = Math.random() * width;
                    this.y = Math.random() * height - height;
                    this.size = Math.random() * 5 + 3;
                    this.speed = Math.random() * 3 + 1.5;
                    this.wind = Math.random() * 1.2 - 0.6;
                    this.opacity = Math.random() * 0.8 + 0.4;
                    this.angle = Math.random() * Math.PI * 2;
                }
                update() {
                    this.y += this.speed;
                    this.x += Math.sin(this.angle) * this.wind;
                    this.angle += 0.02;
                    if (this.y > height + 10) this.reset();
                }
                draw() {
                    ctx.save();
                    ctx.globalAlpha = this.opacity;
                    ctx.fillStyle = "#ffffff";
                    ctx.beginPath();
                    ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                    ctx.fill();
                    ctx.restore();
                }
            }

            const dots = [];
            for (let i = 0; i < 450; i++) dots.push(new WhiteDot());

            function animate() {
                ctx.clearRect(0, 0, width, height);
                for (let dot of dots) {
                    dot.update();
                    dot.draw();
                }
                requestAnimationFrame(animate);
            }
            animate();

            // 5秒後に文字の雪
            setTimeout(() => {
                document.getElementById('text-snow').style.display = "block";
                startTextSnow();
            }, 5000);

            function startTextSnow() {
                const container = document.getElementById('text-snow');
                const words = ["ゆき", "雪", "しんしん", "こんこん", "snow", "SNOW", "Snowflake", "❄️"];

                function createText() {
                    const text = document.createElement("div");
                    text.style.position = "absolute";
                    text.style.color = "#ffffff";
                    text.style.fontSize = (Math.random() * 1.2 + 1.4) + "em";
                    text.style.left = (Math.random() * 98 + 1) + "vw";
                    text.style.top = "-50px";
                    text.style.opacity = "0.9";
                    text.style.transition = "top 6s linear, transform 6s linear";
                    text.textContent = words[Math.floor(Math.random() * words.length)];
                    container.appendChild(text);

                    setTimeout(() => {
                        text.style.top = "105vh";
                        text.style.transform = `rotate(${Math.random()*360}deg)`;
                    }, 50);

                    setTimeout(() => text.remove(), 6500);
                }

                setInterval(createText, 120);
                for (let i = 0; i < 40; i++) setTimeout(createText, i * 60);
            }

            // 20秒後にsnowstop
            setTimeout(() => {
                document.getElementById('final-scene').style.opacity = "1";
                
                // 10秒ごとにリピート
                setTimeout(() => {
                    location.reload(); 
                }, 10000);
            }, 20000);
        }

        startCycle();
    </script>
</body>
</html> 
